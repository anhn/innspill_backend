                <mxCell id="fetchContext" value="Lấy ngữ cảnh từ Cơ sở dữ liệu&lt;br&gt;Bài nộp, Nhiệm vụ, Dự án&lt;br&gt;lịch sử bài nộp/phản hồi trước đó&lt;br&gt;câu trả lời suy ngẫm&lt;br&gt;chân dung bên liên quan (stakeholder)&lt;br&gt;tập tin đính kèm" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
                    <mxGeometry x="80" y="420" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="buildRequest" value="Xây dựng yêu cầu cho tác tử&lt;br&gt;&lt;b&gt;Bài làm học sinh&lt;/b&gt;: bài nộp, câu trả lời, lịch sử&lt;br&gt;&lt;b&gt;Ngữ cảnh nhiệm vụ&lt;/b&gt;: tiêu đề, mô tả,&lt;br&gt;kết quả đạt được, hướng dẫn, tiêu chí&lt;br&gt;&lt;b&gt;Dự án&lt;/b&gt;: mục tiêu học tập (learningOutcome)&lt;br&gt;&lt;b&gt;Chế độ (Mode)&lt;/b&gt;: chung/fewshot/dựa trên luật/v.v." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" parent="1" vertex="1">
