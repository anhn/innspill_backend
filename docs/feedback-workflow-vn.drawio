                </mxCell>
                <mxCell id="workflow" value="new FeedbackWorkflow(openai)&lt;br&gt;process(request)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="490" y="150" width="260" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="generation" value="1. FeedbackGenerationAgent&lt;br&gt;Mô hình: gpt-5.4-mini&lt;br&gt;Xây dựng câu lệnh có cấu trúc&lt;br&gt;Trả về bản JSON phản hồi ban đầu&lt;br&gt;phản hồi/định hướng/khái niệm/&lt;div&gt;suy ngẫm/tư duy phản biện/điểm số&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="490" y="280" width="310" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="evaluation" value="2. FeedbackEvaluationAgent&lt;br&gt;Mô hình: gpt-5.4-mini&lt;br&gt;Đánh giá phản hồi được tạo, không đánh giá trực tiếp bài làm học sinh&lt;br&gt;Kiểm tra: căn cứ minh chứng, bám sát tiêu chí,&lt;br&gt;nhất quán điểm số, nhất quán ngôn ngữ, chất lượng tổng thể" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="490" y="470" width="330" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="decision" value="Có cần sửa đổi?&lt;br&gt;needsRevision == true&#xa;HOẶC bất kỳ điểm chất lượng nào &lt; 4&#xa;VÀ hướng dẫn sửa đổi không rỗng" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" parent="1" vertex="1">
                    <mxGeometry x="470" y="690" width="320" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="revision" value="3. FeedbackRevisionAgent&lt;br&gt;Mô hình: gpt-5.4-mini&lt;br&gt;Đầu vào: phản hồi gốc được tạo + hướng dẫn sửa đổi + cùng ngữ cảnh yêu cầu&lt;br&gt;Đầu ra là bản JSON phản hồi chính thức đã sửa đổi&lt;br&gt;số lượt sửa đổi tối đa (maxRevisionPasses) = 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
                    <mxGeometry x="500" y="900" width="330" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="debug" value="Tùy chọn workflowDebug&lt;br&gt;initialResponse (phản hồi ban đầu)&lt;br&gt;evaluationRaw (đánh giá thô)&lt;br&gt;review (đánh giá chuyên gia)&lt;br&gt;revisionInstructions (hướng dẫn sửa đổi)&lt;br&gt;evaluated / revised (đã đánh giá / đã sửa đổi)&lt;br&gt;revisionPasses (số lượt sửa đổi)&lt;br&gt;evaluationFailed (đánh giá thất bại)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" parent="1" vertex="1">
