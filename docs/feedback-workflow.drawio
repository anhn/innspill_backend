                <mxCell id="generation" value="1. FeedbackGenerationAgent&lt;br&gt;Model: gpt-5.4-mini&lt;br&gt;Builds structured prompt&lt;br&gt;Returns initial JSON feedback&lt;br&gt;feedback/feedforward/concept/reflection/criticalThinking/scores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
