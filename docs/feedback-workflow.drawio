                </mxCell>
                <mxCell id="evaluation" value="2. FeedbackEvaluationAgent&lt;br&gt;Model: gpt-5.4-mini&lt;br&gt;Evaluates generated feedback, not student work directly&lt;br&gt;Checks: evidence grounding, rubric alignment,&lt;br&gt;score consistency, language consistency, overall quality" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" parent="1" vertex="1">
