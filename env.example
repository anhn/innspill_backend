# Session Configuration
SESSION_SECRET=your_session_secret_here

# Environment
NODE_ENV=development

# Social Authentication
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URLs
CLIENT_URL=http://localhost:8080
SERVER_URL=http://localhost:3000

# Database
MONGO_URI=your_mongodb_connection_string

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Server Configuration
PORT=3000

# Base Path Configuration
# IMPORTANT: Leave this EMPTY for BOTH local development AND cPanel deployment!
# 
# For LOCAL: BASE_PATH= (empty)
# For cPanel: BASE_PATH= (empty) - Passenger handles the path automatically
#
# Only set this if you're using a reverse proxy that doesn't strip the base path
BASE_PATH=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

